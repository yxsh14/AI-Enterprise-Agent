# Jira Cloud integration.
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your_api_token
JIRA_PROJECT_KEY=HELP

# Confluence Cloud integration.
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_EMAIL=you@company.com
CONFLUENCE_API_TOKEN=your_api_token
# Use either CONFLUENCE_SPACE_ID or CONFLUENCE_SPACE_KEY.
CONFLUENCE_SPACE_ID=
CONFLUENCE_SPACE_KEY=~71202078a62f5998164338bb9ae1ef09699bd9
# Use either one folder id, multiple comma-separated folder ids, or leave both blank to search the whole space.
CONFLUENCE_FOLDER_ID=
CONFLUENCE_FOLDER_IDS=1277953,1638401,1179656
# Optional. Leave blank to search all pages in the folder/space.
CONFLUENCE_PAGE_TITLE_FILTER=
CONFLUENCE_PAGE_SUBTYPE=live

# Optional LLM planning and synthesis. Leave disabled for deterministic routing.
ENABLE_LLM=false
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.5
